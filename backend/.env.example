# Database
DATABASE_URL=postgresql://pump_user:YOUR_DB_PASSWORD@db:5432/pump?schema=public
DB_PASS=YOUR_DB_PASSWORD

# JWT
JWT_SECRET=YOUR_JWT_SECRET_MIN_32_CHARS

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# LINE Login
LINE_CHANNEL_ID=YOUR_LINE_CHANNEL_ID
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET
LINE_CALLBACK_URL=https://yourdomain.com/api/auth/line/callback

# Cloudflare R2
R2_ACCOUNT_ID=YOUR_R2_ACCOUNT_ID
R2_ACCESS_KEY=YOUR_R2_ACCESS_KEY
R2_SECRET_KEY=YOUR_R2_SECRET_KEY
R2_BUCKET=pump
R2_PUBLIC_URL=https://YOUR_R2_PUBLIC_URL.r2.dev

# Google Places API (for import scripts only)
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
